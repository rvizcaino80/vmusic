{
  "name": "salsamania",
  "version": "1.1.2",
  "description": "An Electron application with Vue",
  "main": "./out/main/index.js",
  "author": "Rogers Vizcaino",
  "homepage": "https://github.com/rvizcaino80/vmusic",
  "repository": {
    "type": "git",
    "url": "https://github.com/rvizcaino80/vmusic.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "start": "electron-vite preview",
    "dev": "electron-vite dev -- --watch --trace-warnings",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac --arm64",
    "build:linux": "npm run build && electron-builder --linux",
    "release:github:mac": "npm run build && electron-builder --mac --arm64 --publish always",
    "release:github:win": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@iconify/vue": "^4.1.1",
    "@sindresorhus/slugify": "^2.2.1",
    "@vueuse/core": "^10.11.1",
    "ant-design-vue": "^4.2.3",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.6",
    "dayjs": "^1.11.11",
    "duration-fns": "^3.0.2",
    "entities": "^4.5.0",
    "express": "^5.2.1",
    "googleapis": "^73.0.0",
    "helmet": "^8.1.0",
    "music-metadata": "^11.12.1",
    "sequelize": "^6.37.2",
    "sqlite3": "^5.1.7",
    "update-electron-app": "^3.0.0",
    "wavesurfer.js": "^7.9.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.1",
    "@iconify/json": "^2.2.235",
    "@rushstack/eslint-patch": "^1.6.1",
    "@stylistic/eslint-plugin-js": "^2.2.2",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/compiler-sfc": "^3.4.37",
    "@vue/eslint-config-prettier": "^9.0.0",
    "autoprefixer": "^10.4.19",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.15",
    "electron-vite": "^3.1.0",
    "eslint": "^9.5.0",
    "eslint-plugin-vue": "^9.26.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.3",
    "unplugin-icons": "^0.19.2",
    "unplugin-vue-components": "^0.27.3",
    "vite": "^5.0.12",
    "vue": "^3.4.15"
  }
}
